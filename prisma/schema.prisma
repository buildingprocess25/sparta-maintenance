// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Ingat konfigurasi URL ada di prisma.config.ts
}

// =========================================
// ENUMS
// =========================================

enum UserRole {
  BMS
  BMC
  BNM_MANAGER
  ADMIN
}

enum ReportStatus {
  DRAFT
  PENDING_ESTIMATION          // BMS submitted, waiting BMC estimation review
  ESTIMATION_APPROVED         // BMC approved estimation, BMS can start work
  ESTIMATION_REJECTED_REVISION // BMC rejected estimation, BMS must revise
  ESTIMATION_REJECTED         // BMC permanently rejected (report closed)
  IN_PROGRESS                 // BMS is working on the report
  PENDING_REVIEW              // BMS finished, waiting BMC completion review
  REVIEW_REJECTED_REVISION    // BMC rejected work, BMS must revise
  APPROVED_BMC                // BMC approved work, waiting BnM Manager
  COMPLETED                   // BnM Manager approved — report done
}

enum ItemCondition {
  BAIK
  RUSAK
  TIDAK_ADA
}

enum PreventiveCondition {
  OK
  NOT_OK
}

enum HandlerType {
  BMS
  REKANAN
}

enum ActivityAction {
  SUBMITTED                   // BMS submitted initial report
  RESUBMITTED_ESTIMATION      // BMS resubmitted after estimation rejection/revision
  RESUBMITTED_WORK            // BMS resubmitted after work rejection/revision
  WORK_STARTED                // BMS started work on approved report
  COMPLETION_SUBMITTED        // BMS submitted work completion for review
  ESTIMATION_APPROVED         // BMC approved estimation
  ESTIMATION_REJECTED_REVISION // BMC rejected estimation, requested revision
  ESTIMATION_REJECTED         // BMC permanently rejected report
  WORK_APPROVED               // BMC approved work completion (forwarded to BnM)
  WORK_REJECTED_REVISION      // BMC rejected work completion, requested revision
  FINALIZED                   // BnM Manager gave final approval
}

// =========================================
// MODELS
// =========================================

model User {
  NIK           String        @id
  email         String        @unique
  name          String
  role          UserRole      @default(BMS)
  branchNames   String[]      // Satu BMS punya 1 branch, BMC bisa 1-N branches
  
  reports       Report[]      @relation("CreatedReports")
  approvals     ApprovalLog[]
  activities    ActivityLog[]
}

model Store {
  code       String   @id @unique 
  name       String                 
  branchName String                 
  
  reports    Report[]
  
  @@index([branchName])
}

model Report {
  reportNumber  String        @id @unique 
  branchName    String        
  storeName     String        @default("")
  
  storeCode     String?       
  store         Store?        @relation(fields: [storeCode], references: [code])
  
  status        ReportStatus  @default(DRAFT)
  totalEstimation Decimal     @default(0) @db.Decimal(15, 2)
  
  createdByNIK  String
  createdBy     User          @relation("CreatedReports", fields: [createdByNIK], references: [NIK])
  
  // JSONB columns — replaces ReportItem[] and MaterialEstimation[]
  items         Json          @default("[]")
  estimations   Json          @default("[]")
  
  logs          ApprovalLog[]
  activities    ActivityLog[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([createdByNIK])
  @@index([status])
  @@index([storeCode])
  @@index([createdByNIK, status])
  @@index([storeCode, status])
}

model ApprovalLog {
  id            String    @id @default(uuid())
  reportNumber  String
  approverNIK   String    
  
  status        ReportStatus 
  notes         String?      
  
  report        Report    @relation(fields: [reportNumber], references: [reportNumber])
  approver      User      @relation(fields: [approverNIK], references: [NIK])
  
  createdAt     DateTime  @default(now())
}

model ActivityLog {
  id            String         @id @default(uuid())
  reportNumber  String
  actorNIK      String

  action        ActivityAction
  notes         String?

  report        Report    @relation(fields: [reportNumber], references: [reportNumber])
  actor         User      @relation(fields: [actorNIK], references: [NIK])

  createdAt     DateTime  @default(now())

  @@index([reportNumber])
  @@index([actorNIK])
}