// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Ingat konfigurasi URL ada di prisma.config.ts
}

// =========================================
// ENUMS
// =========================================

enum UserRole {
  BMS
  BMC
  BNM_MANAGER
  BRANCH_ADMIN
  ADMIN
}

enum PjumStatus {
  PENDING_APPROVAL    // BMC submitted, menunggu BnM Manager
  APPROVED            // BnM Manager menyetujui
  REJECTED            // BnM Manager menolak
}

enum ReportStatus {
  DRAFT
  PENDING_ESTIMATION          // BMS submitted, waiting BMC estimation review
  ESTIMATION_APPROVED         // BMC approved estimation, BMS can start work
  ESTIMATION_REJECTED_REVISION // BMC rejected estimation, BMS must revise
  ESTIMATION_REJECTED         // BMC permanently rejected (report closed)
  IN_PROGRESS                 // BMS is working on the report
  PENDING_REVIEW              // BMS finished, waiting BMC completion review
  APPROVED_BMC                // BMC approved completion, waiting BnM final review
  REVIEW_REJECTED_REVISION    // BMC rejected work, BMS must revise
  COMPLETED                   // Final approved by BnM Manager
}

enum ItemCondition {
  BAIK
  RUSAK
  TIDAK_ADA
}

enum PreventiveCondition {
  OK
  NOT_OK
}

enum HandlerType {
  BMS
  REKANAN
}

enum ActivityAction {
  SUBMITTED                   // BMS submitted initial report
  RESUBMITTED_ESTIMATION      // BMS resubmitted after estimation rejection/revision
  RESUBMITTED_WORK            // BMS resubmitted after work rejection/revision
  WORK_STARTED                // BMS started work on approved report
  COMPLETION_SUBMITTED        // BMS submitted work completion for review
  ESTIMATION_APPROVED         // BMC approved estimation
  ESTIMATION_REJECTED_REVISION // BMC rejected estimation, requested revision
  ESTIMATION_REJECTED         // BMC permanently rejected report
  WORK_APPROVED               // BMC approved work completion (forwarded to BnM)
  WORK_REJECTED_REVISION      // BMC rejected work completion, requested revision
  FINAL_APPROVED_BNM          // BnM Manager gave final approval
  FINAL_REJECTED_REVISION_BNM // BnM Manager rejected and returned for revision
}

// =========================================
// MODELS
// =========================================

model User {
  NIK                String        @id
  email              String        @unique
  name               String
  role               UserRole      @default(BMS)
  branchNames        String[]      // Satu BMS punya 1 branch, BMC bisa 1-N branches
  passwordHash       String?       // null = legacy user, login pakai branch name
  mustChangePassword Boolean       @default(true) // true = paksa ganti password saat login
  
  reports       Report[]      @relation("CreatedReports")
  approvals     ApprovalLog[]
  activities    ActivityLog[]
}

model GoogleDriveFolderCache {
  id         String   @id @default(uuid())
  cacheKey   String   @unique
  folderId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Store {
  code       String   @id @unique 
  name       String                 
  branchName String                 
  
  reports    Report[]
  
  @@index([branchName])
}

model Report {
  reportNumber  String        @id @unique 
  branchName    String        
  storeName     String        @default("")
  
  storeCode     String?       
  store         Store?        @relation(fields: [storeCode], references: [code])
  
  status        ReportStatus  @default(DRAFT)
  totalEstimation Decimal     @default(0) @db.Decimal(15, 2)
  
  createdByNIK  String
  createdBy     User          @relation("CreatedReports", fields: [createdByNIK], references: [NIK])
  
  // JSONB columns — replaces ReportItem[] and MaterialEstimation[]
  items         Json          @default("[]")
  estimations   Json          @default("[]")
  
  // Start-work data (captured when BMS clicks "Mulai Pengerjaan")
  startSelfieUrl       String?   // selfie photo(s) taken by BMS at start (JSON array or single URL)
  startReceiptUrls     Json      @default("[]")  // nota/receipt photos taken at start
  startMaterialStores  Json      @default("[]")  // toko material + kota yang diinput BMS saat start-work

  // Completion data
  completionNotes      String?   // notes during completion
  completionAdditionalPhotos Json @default("[]") // additional completion documentation photos
  completionAdditionalNote   String? // one note for additional completion documentation set
  finishedAt           DateTime? // when report was marked as finished/completed

  // PJUM — tracks when this report was included in a PJUM export
  pjumExportedAt       DateTime?

  // PDF snapshot paths in Supabase Storage (bucket: reports)
  pendingEstimationPdfPath  String?
  estimationApprovedPdfPath String?
  approvedBmcPdfPath        String?
  completedPdfPath          String?
  pdfSnapshotMeta           Json      @default("{}")

  // Final archival pointer in Google Drive (uploaded at PJUM final approval)
  reportFinalDriveUrl       String?
  
  logs          ApprovalLog[]
  activities    ActivityLog[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([createdByNIK])
  @@index([status])
  @@index([storeCode])
  @@index([createdByNIK, status])
  @@index([storeCode, status])
}

model ApprovalLog {
  id            String    @id @default(uuid())
  reportNumber  String
  approverNIK   String    
  
  status        ReportStatus 
  notes         String?      
  
  report        Report    @relation(fields: [reportNumber], references: [reportNumber])
  approver      User      @relation(fields: [approverNIK], references: [NIK])
  
  createdAt     DateTime  @default(now())
}

model ActivityLog {
  id            String         @id @default(uuid())
  reportNumber  String
  actorNIK      String

  action        ActivityAction
  notes         String?

  report        Report    @relation(fields: [reportNumber], references: [reportNumber])
  actor         User      @relation(fields: [actorNIK], references: [NIK])

  createdAt     DateTime  @default(now())

  @@index([reportNumber])
  @@index([actorNIK])
}

model PjumExport {
  id              String      @id @default(uuid())
  status          PjumStatus  @default(PENDING_APPROVAL)

  // Filter context
  bmsNIK          String
  branchName      String
  weekNumber      Int
  fromDate        DateTime
  toDate          DateTime

  // Report numbers included in this PJUM
  reportNumbers   String[]

  // BMC who created
  createdByNIK    String

  // BnM Manager who approved
  approvedByNIK   String?
  approvedAt      DateTime?

  // PUM data (filled by BnM Manager on approval)
  pumBankAccountNo    String?
  pumBankAccountName  String?
  pumBankName         String?
  pumWeekNumber       Int?
  pumMonth            String?
  pumYear             Int?

  // Rejection notes
  rejectionNotes  String?

  // PDF snapshot path and final archival URL
  pjumPdfPath      String?
  pjumFinalDriveUrl String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@index([branchName])
  @@index([createdByNIK])
}

model PjumBankAccount {
  id              String   @id @default(uuid())
  bmsNIK          String
  bankAccountNo   String
  bankAccountName String
  bankName        String

  addedByNIK      String   // BnM Manager who added this

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([bmsNIK, bankAccountNo])
  @@index([bmsNIK])
  @@index([addedByNIK])
}
